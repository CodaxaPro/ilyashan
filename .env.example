# Ilyashan – Production Environment Variables
# Kopieren nach .env.local für lokale Entwicklung (nicht committen)

# ── E-Mail (Pflicht für Formulare) ──
RESEND_API_KEY=re_xxxxxxxx
CONTACT_EMAIL=info@ilyashan.de
FROM_EMAIL=Ilyashan Fensterreinigung <info@ilyashan.de>

# ── Admin Panel /admin ──
ADMIN_PASSWORD=ihr-sicheres-passwort

# ── Upstash Redis (Vercel Integration) – Leads + unbekannte Fragen ──
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxx

# ── Google Ads Conversion (optional, empfohlen) ──
# Aus Google Ads → Ziele → request_quote → Event snippet (send_to)
NEXT_PUBLIC_GOOGLE_ADS_REQUEST_QUOTE_SEND_TO=AW-18191480247/xxxxxxxx
